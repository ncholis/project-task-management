{
  "info": {
    "name": "Project & Task Management System API",
    "description": "Postman collection for Project & Task Management System backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": "3"
    },
    {
      "key": "manager_id",
      "value": "2"
    },
    {
      "key": "staff_id",
      "value": "3"
    },
    {
      "key": "project_id",
      "value": "1"
    },
    {
      "key": "task_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Auth Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.token) {",
                  "  pm.environment.set('token', json.data.token);",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Auth Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('user_id', json.data.id);",
                  "  if (json.data.role === 'MANAGER') pm.collectionVariables.set('manager_id', json.data.id);",
                  "  if (json.data.role === 'STAFF') pm.collectionVariables.set('staff_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Staff\",\n  \"username\": \"newstaff\",\n  \"password\": \"password123\",\n  \"email\": \"newstaff@example.com\",\n  \"phone_number\": \"080000000004\",\n  \"role\": \"STAFF\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/users"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/users"
          }
        },
        {
          "name": "Get User Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/users/{{user_id}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Staff\",\n  \"phone_number\": \"080000000099\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/users/{{user_id}}"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.id) pm.collectionVariables.set('project_id', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_name\": \"Mobile API Project\",\n  \"start_date\": \"2026-06-10T00:00:00.000Z\",\n  \"end_date\": \"2026-07-10T00:00:00.000Z\",\n  \"priority\": \"HIGH\",\n  \"manager_id\": {{manager_id}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/projects"
          }
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/projects"
          }
        },
        {
          "name": "Get Project Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/projects/{{project_id}}"
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_name\": \"Updated Mobile API Project\",\n  \"priority\": \"MEDIUM\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/projects/{{project_id}}"
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/projects/{{project_id}}"
          }
        },
        {
          "name": "Assign Manager to Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"manager_id\": {{manager_id}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/projects/{{project_id}}/assign-manager"
          }
        },
        {
          "name": "Get Project Task Tree",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/projects/{{project_id}}/tasks/tree"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.id) pm.collectionVariables.set('task_id', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": {{project_id}},\n  \"parent_id\": null,\n  \"title\": \"Prepare Backend Module\",\n  \"description\": \"Create REST API and workers\",\n  \"status\": \"OPEN\",\n  \"priority\": \"HIGH\",\n  \"start_time\": \"2026-06-10T08:00:00.000Z\",\n  \"end_time\": \"2026-06-12T17:00:00.000Z\",\n  \"assigned_to\": {{staff_id}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/tasks"
          }
        },
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/tasks"
          }
        },
        {
          "name": "Get Task Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/tasks/{{task_id}}"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Prepare Backend Module Updated\",\n  \"priority\": \"MEDIUM\",\n  \"end_time\": \"2026-06-13T17:00:00.000Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/tasks/{{task_id}}"
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/tasks/{{task_id}}"
          }
        },
        {
          "name": "Assign Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assigned_to\": {{staff_id}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/tasks/{{task_id}}/assign"
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"WORKING\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/tasks/{{task_id}}/status"
          }
        }
      ]
    }
  ]
}
